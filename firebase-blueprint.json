{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information including name, email, and profile picture.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string",
          "description": "The user's full name."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "format": "uri",
          "description": "The URL of the user's profile picture."
        },
        "specialization": {
          "type": "string",
          "description": "The user's medical specialization."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        },
        "hospitalName": {
          "type": "string",
          "description": "The name of the hospital."
        },
        "registrationId": {
          "type": "string",
          "description": "The hospital registration ID."
        },
        "address": {
          "type": "string",
          "description": "The hospital address."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the profile was updated."
        }
      },
      "required": ["displayName", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles indexed by their Firebase Auth UID."
    }
  }
}
